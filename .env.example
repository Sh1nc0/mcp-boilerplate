# ===================================
# MCP Server Configuration
# ===================================

# Server name and version
MCP_SERVER_NAME=mcp-boilerplate
MCP_SERVER_VERSION=1.0.0

# Transport mode: "stdio" or "http"
MCP_MODE=http

# ===================================
# Server Settings (HTTP Mode)
# ===================================

# Server host address
HOST=127.0.0.1

# Server port number
PORT=8004

# Log level: "debug", "info", "error"
LOG_LEVEL=info

# ===================================
# External APIs & Services
# ===================================

# Base URL for your API
API_BASE_URL=https://api.example.com

# Optional: API authentication key
# CUSTOM_API_KEY=your-api-key-here

# optional: Database connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Optional: JWT secret for authentication
# JWT_SECRET=your-secret-key-here

# ===================================
# Instructions for usage:
# ===================================
# 1. Copy this file: cp .env.example .env
# 2. Update values in .env with your actual configuration
# 3. Add .env to .gitignore (do not commit secrets!)
# 4. The .env file is loaded automatically on startup
# ===================================
